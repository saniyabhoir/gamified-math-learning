      "dialogue": [
        {
          "character": "NOVA",
          "expression": "dramatic",
          "text": "The Number Kingdom holds a grand contest each year — the Number Showdown! Two numbers face off, and the crowd asks: which one is GREATER?",
          "pause_after": 700
        },
        {
          "character": "ZAP",
          "expression": "excited",
          "text": "Oh! Is it like a fight? Do they have swords?",
          "pause_after": 300
        },
        {
          "character": "NOVA",
          "expression": "amused",
          "text": "Ha! Not quite. We compare them using place value. Always start from the left — the hundreds place first, then tens, then ones.",
          "pause_after": 700
        },
        {
          "character": "NOVA",
          "expression": "teaching",
          "text": "Look at 547 and 539. Both start with 5 in the hundreds — a tie. Move to the tens: 4 vs 3. 4 is bigger! So 547 is greater than 539.",
          "pause_after": 800
        },
        {
          "character": "ZAP",
          "expression": "amazed",
          "text": "You didn't even need to count all the way up! You just looked at the digits.",
          "pause_after": 400
        },
        {
          "character": "NOVA",
          "expression": "warm",
          "text": "That's place value working for you. It's faster, smarter, and way more powerful.",
          "pause_after": 0
        }
      ],
