      "concept": {
        "id": "tens_place",
        "title": "The Tens Place",
        "tag": "place_value"
      },
      "dialogue": [
        {
          "character": "NOVA",
          "expression": "excited",
          "text": "Now we climb higher! Look at this number: 37.",
          "pause_after": 500
        },
        {
          "character": "NOVA",
          "expression": "teaching",
          "text": "Two digits! The 7 on the right is still in the ones place — we know that now. But that 3 on the left? It's in the TENS place.",
          "pause_after": 700
        },
        {
          "character": "ZAP",
          "expression": "surprised",
          "text": "The tens place? So does the 3 mean... 3?",
          "pause_after": 400
        },
        {
          "character": "NOVA",
          "expression": "teaching",
          "text": "Great question! No — that's the kingdom's magic. In the tens place, every digit is worth ten times more. So that 3 doesn't mean 3... it means 3 TENS, which is 30!",
          "pause_after": 800
        },
        {
          "character": "ZAP",
          "expression": "amazed",
          "text": "Woah. So 37 is really 30 and 7 put together?",
          "pause_after": 400
        },
        {
          "character": "NOVA",
          "expression": "celebrating",
          "text": "You just discovered expanded form! 37 = 30 + 7. The position of a digit decides its power. That's the secret of the Number Kingdom.",
          "pause_after": 0
        }
      ],
      "visual_highlight": {
        "type": "digit_spotlight",
