      "concept": {
        "id": "ones_place",
        "title": "The Ones Place",
        "tag": "place_value"
      },
      "dialogue": [
        {
          "character": "NOVA",
          "expression": "curious",
          "text": "Look at this number: 7. Just one digit. Simple, right?",
          "pause_after": 500
        },
        {
          "character": "NOVA",
          "expression": "teaching",
          "text": "That 7 lives in the ONES place. It means we have 7 single things — 7 stars, 7 steps, 7 anything you like.",
          "pause_after": 700
        },
        {
          "character": "ZAP",
          "expression": "thinking",
          "text": "So... the ones place is just counting one by one?",
          "pause_after": 400
        },
        {
          "character": "NOVA",
          "expression": "delighted",
          "text": "Exactly! You've already got it, Zap. The ones place holds individual units — single pieces. Every number starts with a ones place.",
          "pause_after": 600
        },
        {
          "character": "NOVA",
          "expression": "warm",
          "text": "Think of it like this: if numbers were a castle, the ones place is the front door. Every number walks in through ones.",
          "pause_after": 0
        }
      ],
      "visual_highlight": {
        "type": "digit_spotlight",
        "number": "7",
        "highlight_position": "ones",
        "label": "ONES",
        "color": "#6C63FF"
      },
      "xp_value": 10,
      "analytics_event": "screen_s2_ones_intro_viewed"
    },
